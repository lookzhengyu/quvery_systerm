# Frontend remote sync
VITE_QUEUE_SYNC_MODE=remote
VITE_QUEUE_API_BASE_URL=http://127.0.0.1:8787
VITE_DEFAULT_STORE_ID=RESTO-001
# Optional public app URL used when generating merchant QR links.
# Set this in production so downloaded QR codes point to your live domain.
# VITE_PUBLIC_APP_URL=https://queue.yourdomain.com

# Backend store bootstrap
DEFAULT_STORE_ID=RESTO-001
DEFAULT_STORE_PASSWORD=admin123

# Optional backend runtime settings
# Current storage provider: sqlite
# Planned production upgrade path: managed Postgres behind server/store.mjs
# QUEUEFLOW_STORAGE_PROVIDER=sqlite
# QUEUEFLOW_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Optional token for private /health diagnostics. Public /health stays sanitized.
# QUEUEFLOW_HEALTH_TOKEN=replace-with-a-long-random-secret
# QUEUEFLOW_DATA_DIR=./server/.data
#
# Production Postgres example
# QUEUEFLOW_STORAGE_PROVIDER=postgres
# QUEUEFLOW_POSTGRES_URL=postgresql://postgres:password@db.example.com:5432/queueflow
# DATABASE_URL=postgresql://postgres:password@db.example.com:5432/queueflow
# POSTGRES_URL=postgresql://postgres:password@db.example.com:5432/queueflow
# QUEUEFLOW_PG_SSL=require
# QUEUEFLOW_PG_AUTO_INIT=true
# Keep this low on serverless unless your database pooler supports more connections.
# QUEUEFLOW_PG_POOL_MAX=5
# QUEUEFLOW_PG_IDLE_TIMEOUT_MS=10000
# QUEUEFLOW_PG_CONNECTION_TIMEOUT_MS=5000
#
# Supabase example (transaction pooler)
# QUEUEFLOW_STORAGE_PROVIDER=postgres
# QUEUEFLOW_POSTGRES_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# QUEUEFLOW_PG_SSL=require

# Optional email notifications
# Use ONE method below:
#
# 1. Standard SMTP (recommended for production)
# QUEUE_SMTP_HOST=smtp.yourprovider.com
# QUEUE_SMTP_PORT=587
# QUEUE_SMTP_SECURE=false
# QUEUE_SMTP_USER=your-smtp-user
# QUEUE_SMTP_PASSWORD=your-smtp-password
# QUEUE_EMAIL_FROM=QueueFlow <noreply@yourdomain.com>
#
# 2. Gmail SMTP (good for testing or small volume)
# Use a Gmail app password, not your normal Gmail password.
# QUEUE_GMAIL_USER=your@gmail.com
# QUEUE_GMAIL_APP_PASSWORD=your-16-char-app-password
# QUEUE_EMAIL_FROM=QueueFlow <your@gmail.com>

# Optional web push notifications for customer background alerts
# Generate once with: npx web-push generate-vapid-keys --json
# Required for Android/Chrome, desktop browsers, and iOS/iPadOS 16.4+ Home Screen web apps.
# iOS customers must add the QR page to Home Screen and open the app from that icon before enabling alerts.
# VITE_WEB_PUSH_VAPID_PUBLIC_KEY=BK...
# QUEUE_WEB_PUSH_VAPID_PUBLIC_KEY=BK...
# QUEUE_WEB_PUSH_VAPID_PRIVATE_KEY=...
# QUEUE_WEB_PUSH_SUBJECT=https://queue.yourdomain.com

# Optional Stripe monthly merchant billing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# QUEUEFLOW_STRIPE_CURRENCY=usd
# QUEUEFLOW_STRIPE_STARTER_MONTHLY_AMOUNT=4900
# QUEUEFLOW_STRIPE_GROWTH_MONTHLY_AMOUNT=9900
# QUEUEFLOW_STRIPE_SCALE_MONTHLY_AMOUNT=19900
